# Copy to .env and fill in your values. Never commit .env.
PORT=5000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=E-Commerce
DB_SSL=false
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret
APP_NAME=Your E-Commerce Store
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ICECAT_API_KEY=
ICECAT_CONTENT_TOKEN=
FTP_API_BASE_URL=https://test.vcloudtech.net/api
FTP_API_EMAIL=
FTP_API_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
